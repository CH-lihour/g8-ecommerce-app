rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Shop catalogue: readable by anyone, never written from the client.
    match /products/{doc} {
      allow read: if true;
      allow write: if false;
    }
    match /categories/{doc} {
      allow read: if true;
      allow write: if false;
    }

    // Each signed-in user can read/write only their own profile doc.
    // Covers register, phone sign-up, profile updates, and the Facebook
    // sign-in / account-link upsert in AuthService.
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
